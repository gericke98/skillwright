{
  "name": "skillwright-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Browser Skill Learner — capture a browser task once, replay it as a portable Agent Skill",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx packages/evals/src/run-evals.ts",
    "typecheck": "tsc --build",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@11.1.3"
}
